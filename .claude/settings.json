      "Bash(aws logs describe-*)",
      "Bash(aws logs get-log-events *)",
      "Bash(aws rds describe-*)",
      "Bash(aws iam get-*)",
      "Bash(aws iam list-*)",
      "Bash(gh api repos/*)",
